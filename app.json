{
  "expo": {
    "name": "PlantScope",
    "slug": "plantscope-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plantscopemobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "PlantScope uses your camera to take a photo of a leaf to check it for disease, entirely on this device.",
        "NSPhotoLibraryUsageDescription": "PlantScope uses your photo library so you can choose an existing leaf photo to check, entirely on this device."
      },
      "bundleIdentifier": "com.plantscope.basil"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2c4733",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "PlantScope uses your camera to take a photo of a leaf to check it for disease, entirely on this device.",
          "photosPermission": "PlantScope uses your photo library so you can choose an existing leaf photo to check, entirely on this device."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f6f1e3",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
